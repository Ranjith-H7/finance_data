{
  "name": "kitchen-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "npm --prefix backend run dev",
    "dev:all": "concurrently -n backend,frontend -c blue,green \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "test:backend": "npm --prefix backend run test",
    "typecheck:backend": "npm --prefix backend run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
